# ===========================================
# 智研助手 - 生产环境配置
# ===========================================

# 基础配置
COZE_PROJECT_DOMAIN_DEFAULT=https://your-domain.com
DEPLOY_RUN_PORT=5000
NODE_ENV=production

# ══════════════════════════════════════════
#  AI 能力配置 — LLM Provider 选择
# ══════════════════════════════════════════
#
# ┌──────────────────────────────────────┐
# │  方案 1: SiliconFlow（推荐，国内可用）│
# │  DeepSeek/Qwen/GLM 等，注册送额度    │
# │  https://cloud.siliconflow.cn        │
# │  AI_PROVIDER=siliconflow             │
# │  AI_API_KEY=sk-你的Key               │
# ├──────────────────────────────────────┤
# │  方案 2: Google Gemini REST API      │
# │  免费 API Key，服务端直接调用         │
# │  https://aistudio.google.com/apikey  │
# │  AI_PROVIDER=gemini                  │
# │  AI_API_KEY=你的Google AI Studio Key │
# ├──────────────────────────────────────┤
# │  方案 3: OpenAI / DeepSeek 官方      │
# │  需要付费 API Key                    │
# │  AI_PROVIDER=openai 或 deepseek      │
# │  AI_API_KEY=sk-你的Key               │
# ├──────────────────────────────────────┤
# │  方案 4: 自定义任意 OpenAI 兼容 API   │
# │  AI_PROVIDER=custom                 │
# │  AI_BASE_URL=https://xxx/v1          │
# │  AI_API_KEY=sk-xxx                   │
# │  AI_MODEL=模型名                     │
# └──────────────────────────────────────┘

# ---- 当前选择（取消注释并修改为你想要的 Provider）----
AI_PROVIDER=siliconflow

# ---- 可选：API 密钥（SiliconFlow/Gemini/OpenAI 等需要）----
AI_API_KEY=sk-ujygfvjedtjnjfboxqfmzmcbvkpbglttuqoiijcjxnyvzmql
# AI_BASE_URL=
# AI_BASE_URL=
# AI_MODEL=

# ══════════════════════════════════════════
#  联网搜索配置（政策搜索功能需要）
# ══════════════════════════════════════════
#
# ┌──────────────────────────────────────┐
# │  百度搜索建议（推荐，免费稳定）      │
# │  官方接口，无需 Key，国内可用        │
# │  SEARCH_PROVIDER=baidu              │
# ├──────────────────────────────────────┤
# │  Bing Search（备选）                 │
# │  Azure 每月 1000 次免费             │
# │  https://portal.azure.com           │
# │  SEARCH_PROVIDER=bing               │
# │  SEARCH_API_KEY=你的Bing Key         │
# ├──────────────────────────────────────┤
# │  Tavily（备选，1000次/月免费）        │
# │  https://app.tavily.com              │
# │  SEARCH_PROVIDER=tavily              │
# │  SEARCH_API_KEY=tvly-你的Key         │
# ├──────────────────────────────────────┤
# │  DuckDuckGo（默认，零配置）           │
# │  国内服务器可能不可用                 │
# │  不设置 SEARCH_PROVIDER 即自动使用    │
# └──────────────────────────────────────┘

SEARCH_PROVIDER=baidu
# SEARCH_API_KEY=
