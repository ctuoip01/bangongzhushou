# ===========================================
# 智研助手 - 生产环境配置
# ===========================================

# 基础配置
COZE_PROJECT_DOMAIN_DEFAULT=https://your-domain.com
DEPLOY_RUN_PORT=5000
NODE_ENV=production

# ══════════════════════════════════════════
#  AI 能力配置 — LLM Provider 选择
# ══════════════════════════════════════════
#
# ┌──────────────────────────────────────┐
# │  方案 1: Puter.js（推荐，零配置）     │
# │  免费 Google Gemini/Gemma，无需 Key   │
# │  AI_PROVIDER=puter                  │
# │  （默认值，不配置即使用）              │
# ├──────────────────────────────────────┤
# │  方案 2: SiliconFlow（国内免费聚合）  │
# │  DeepSeek/Qwen/GLM 等               │
# │  https://cloud.siliconflow.cn        │
# │  AI_PROVIDER=siliconflow             │
# │  AI_API_KEY=sk-你的Key               │
# ├──────────────────────────────────────┤
# │  方案 3: OpenAI / DeepSeek 官方      │
# │  需要付费 API Key                    │
# │  AI_PROVIDER=openai 或 deepseek      │
# │  AI_API_KEY=sk-你的Key               │
# ├──────────────────────────────────────┤
# │  方案 4: 自定义任意 OpenAI 兼容 API   │
# │  AI_PROVIDER=custom                 │
# │  AI_BASE_URL=https://xxx/v1          │
# │  AI_API_KEY=sk-xxx                   │
# │  AI_MODEL=模型名                     │
# └──────────────────────────────────────┘

# ---- 当前选择（取消注释并修改为你想要的 Provider）----
AI_PROVIDER=puter

# ---- 可选：API 密钥（Puter 不需要，其他大多需要）----
# AI_API_KEY=
# AI_BASE_URL=
# AI_MODEL=

# ══════════════════════════════════════════
#  联网搜索配置（政策搜索功能需要）
# ══════════════════════════════════════════
#
# ┌──────────────────────────────────────┐
# │  DuckDuckGo（默认，零配置免费）       │
# │  不设置任何 SEARCH_* 即自动使用       │
# ├──────────────────────────────────────┤
# │  Tavily（推荐，1000次/月免费）        │
# │  https://app.tavily.com              │
# │  SEARCH_PROVIDER=tavily              │
# │  SEARCH_API_KEY=tvly-你的Key         │
# ├──────────────────────────────────────┤
# │  Coze 沙箱搜索                       │
# │  仅限 Coze 平台内运行                 │
# │  SEARCH_PROVIDER=coze                │
# └──────────────────────────────────────┘

# ---- 当前搜索方案（默认 DuckDuckGo）----
# SEARCH_PROVIDER=
# SEARCH_API_KEY=
