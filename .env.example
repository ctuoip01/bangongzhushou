# ===========================================
# 智研助手 - 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填写实际值
# 本地开发使用 .env.local，生产环境使用 .env.production

# ===========================================
# 必填配置
# ===========================================

# 访问域名（用于生成正确的 URL）
# 开发环境： http://localhost:5000
# 生产环境： https://your-domain.com
COZE_PROJECT_DOMAIN_DEFAULT=http://localhost:5000

# 服务端口（固定 5000）
DEPLOY_RUN_PORT=5000

# ===========================================
# AI 能力配置（可选）
# ===========================================
# 如果使用沙箱内置 AI，保持为空即可
# 如果接入其他 AI 服务，请参考下方配置

# AI Provider: sandbox | deepseek | kimi | zhipu
# AI_PROVIDER=sandbox

# DeepSeek API（https://platform.deepseek.com）
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Kimi API（https://platform.moonshot.cn）
# KIMI_API_KEY=your-kimi-key

# 智谱 GLM API（https://open.bigmodel.cn）
# ZHIPU_API_KEY=your-zhipu-key

# ===========================================
# 可选配置
# ===========================================

# Node 环境
NODE_ENV=development

# 日志级别
# LOG_LEVEL=info | debug | error
# LOG_LEVEL=info

# 是否启用详细错误信息（生产环境建议关闭）
# SHOW_ERROR_DETAILS=false
